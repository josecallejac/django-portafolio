# Copia este archivo como `.env` para desarrollo local.
#
# PostgreSQL local (para usar con DBeaver / Docker / Postgres instalado)
# Ejemplo:
#   Host: localhost
#   Port: 5432
#   Database: portfolio
#   Username: postgres
#   Password: postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# Por defecto el proyecto exige SSL en entornos remotos.
# En local normalmente Postgres no trae SSL configurado, así que déjalo en 0.
DATABASE_SSL_REQUIRE=0

